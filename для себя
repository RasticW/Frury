<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Remote PC</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; user-select:none; }
  html,body { height:100%; background:#000; font-family:system-ui,sans-serif; overflow:hidden; color:#fff; }
  #wrap { display:flex; flex-direction:column; height:100%; }
  #screenBox { flex:1; position:relative; background:#111; overflow:hidden; touch-action:none; }
  #screen { width:100%; height:100%; object-fit:contain; display:block; }
  #overlay { position:absolute; inset:0; touch-action:none; }
  #toolbar { display:flex; flex-wrap:wrap; gap:6px; padding:6px; background:#1a1a1a; }
  .btn { background:#2d2d2d; border:1px solid #444; color:#fff; padding:8px 10px; border-radius:8px; font-size:13px; min-width:44px; text-align:center; }
  .btn:active { background:#3d6bff; }
  .btn.k { flex:1; }
  #keyboard { display:none; flex-wrap:wrap; gap:4px; padding:6px; background:#1a1a1a; }
  #keyboard.show { display:flex; }
  #keyinput { flex:1 1 100%; background:#000; color:#fff; border:1px solid #444; border-radius:8px; padding:10px; font-size:16px; }
  .small { font-size:11px; }
  #status { position:absolute; top:6px; left:6px; font-size:11px; background:rgba(0,0,0,.5); padding:4px 8px; border-radius:6px; }
  #conn { color:#4f4; }
  #conn.bad { color:#f55; }
</style>
</head>
<body>
<div id="wrap">
  <div id="screenBox">
    <img id="screen" src="" alt="">
    <div id="overlay"></div>
    <div id="status">Статус: <span id="conn">подключение...</span></div>
  </div>

  <div id="toolbar">
    <div class="btn" id="btnLeft">ЛКМ</div>
    <div class="btn" id="btnRight">ПКМ</div>
    <div class="btn" id="btnScroll">Скролл</div>
    <div class="btn" id="btnKey">Клавиатура</div>
    <div class="btn" id="btnWin">Win</div>
    <div class="btn" id="btnEsc">Esc</div>
    <div class="btn" id="btnReload">⟳</div>
  </div>

  <div id="keyboard">
    <input id="keyinput" type="text" placeholder="Введите текст и нажмите Enter">
    <div class="btn k" data-key="enter">Enter</div>
    <div class="btn k" data-key="backspace">⌫</div>
    <div class="btn k" data-key="tab">Tab</div>
    <div class="btn k" data-key="space">Пробел</div>
    <div class="btn k" data-key="up">↑</div>
    <div class="btn k" data-key="down">↓</div>
    <div class="btn k" data-key="left">←</div>
    <div class="btn k" data-key="right">→</div>
    <div class="btn k" data-key="ctrl">Ctrl</div>
    <div class="btn k" data-key="alt">Alt</div>
    <div class="btn k" data-key="delete">Del</div>
  </div>
</div>

<script>
const screenEl = document.getElementById('screen');
const overlay = document.getElementById('overlay');
const connEl = document.getElementById('conn');
let screenW = 0, screenH = 0;
let lastMoveSent = 0;
let moveTimer = null;
let dragging = false;
let scrollMode = false;
let lastTouch = null;

function post(url, data){
  return fetch(url, {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data)})
    .catch(()=>{});
}

function refreshScreen(){
  const t = Date.now();
  screenEl.src = '/api/screen?t=' + t;
}
screenEl.onload = ()=>{
  connEl.textContent = 'онлайн';
  connEl.className = '';
  setTimeout(refreshScreen, 150);
};
screenEl.onerror = ()=>{
  connEl.textContent = 'нет связи';
  connEl.className = 'bad';
  setTimeout(refreshScreen, 1000);
};

function getScreenSize(){
  return fetch('/api/status').then(r=>r.json()).then(()=>{}).catch(()=>{});
}

function clientToScreen(clientX, clientY){
  const rect = screenEl.getBoundingClientRect();
  const x = (clientX - rect.left) / rect.width;
  const y = (clientY - rect.top) / rect.height;
  return { rx: x, ry: y };
}

function sendMove(clientX, clientY){
  const {rx, ry} = clientToScreen(clientX, clientY);
  const now = Date.now();
  if (now - lastMoveSent < 16) return;
  lastMoveSent = now;
  post('/api/move', {x: Math.round(rx*100000), y: Math.round(ry*100000)});
}

overlay.addEventListener('touchstart', (e)=>{
  e.preventDefault();
  const t = e.touches[0];
  lastTouch = {x:t.clientX, y:t.clientY};
  const {rx, ry} = clientToScreen(t.clientX, t.clientY);
  if (scrollMode){
    return;
  }
  if (dragging){
    post('/api/down', {x:Math.round(rx*100000), y:Math.round(ry*100000)});
  }
}, {passive:false});

overlay.addEventListener('touchmove', (e)=>{
  e.preventDefault();
  const t = e.touches[0];
  if (scrollMode && lastTouch){
    const dy = t.clientY - lastTouch.y;
    const dx = t.clientX - lastTouch.x;
    post('/api/scroll', {dx:Math.round(dx), dy:Math.round(dy)});
    lastTouch = {x:t.clientX, y:t.clientY};
    return;
  }
  sendMove(t.clientX, t.clientY);
}, {passive:false});

overlay.addEventListener('touchend', (e)=>{
  e.preventDefault();
  const {rx, ry} = clientToScreen(lastTouch.x, lastTouch.y);
  if (scrollMode){
    scrollMode = false;
    return;
  }
  if (dragging){
    post('/api/up', {x:Math.round(rx*100000), y:Math.round(ry*100000)});
  } else {
    post('/api/tap', {x:Math.round(rx*100000), y:Math.round(ry*100000)});
  }
}, {passive:false});

document.getElementById('btnLeft').ontouchstart = (e)=>{ e.preventDefault(); dragging = false; };
document.getElementById('btnRight').ontouchstart = (e)=>{ e.preventDefault(); post('/api/key',{key:'f10'}); };
document.getElementById('btnRight').addEventListener('click', ()=> post('/api/key',{key:'f10'}));
document.getElementById('btnScroll').ontouchstart = (e)=>{ e.preventDefault(); scrollMode = !scrollMode; e.target.style.background = scrollMode ? '#3d6bff' : '#2d2d2d'; };
document.getElementById('btnScroll').addEventListener('click', (e)=>{ scrollMode = !scrollMode; e.target.style.background = scrollMode ? '#3d6bff' : '#2d2d2d'; });
document.getElementById('btnWin').addEventListener('click', ()=> post('/api/key',{key:'win'}));
document.getElementById('btnEsc').addEventListener('click', ()=> post('/api/key',{key:'esc'}));
document.getElementById('btnReload').addEventListener('click', ()=> refreshScreen());

document.getElementById('btnLeft').addEventListener('click', ()=>{ dragging = false; });
document.getElementById('btnLeft').addEventListener('touchstart', (e)=>{ e.preventDefault(); dragging = false; });

const kb = document.getElementById('keyboard');
document.getElementById('btnKey').addEventListener('click', ()=> kb.classList.toggle('show'));

document.getElementById('keyinput').addEventListener('keydown', (e)=>{
  if (e.key === 'Enter'){
    const v = e.target.value;
    if (v) post('/api/type', {text:v});
    e.target.value = '';
  }
});

kb.querySelectorAll('[data-key]').forEach(b=>{
  b.addEventListener('click', ()=>{
    post('/api/key', {key: b.getAttribute('data-key')});
  });
});

getScreenSize();
refreshScreen();
</script>
</body>
</html>
